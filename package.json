{
  "name": "@mcbalaam/razdor-ui",
  "version": "0.1.17",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target browser --format esm --external react --external react-dom --external @fortawesome/fontawesome-svg-core && bun run build:types",
    "build:types": "tsc --project tsconfig.build.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0"
  },
  "devDependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@storybook/global": "^5.0.0",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "storybook": "^10.2.19",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
